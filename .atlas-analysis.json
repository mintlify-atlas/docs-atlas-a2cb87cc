  "keyFeatures": [
    "LSM-based storage engine optimized for write-heavy workloads",
    "PostgreSQL wire protocol compatibility for easy client integration",
    "Distributed architecture with sharding and replication",
    "SQL support with joins, aggregations, and transactions",
    "Built-in authentication, TLS encryption, and audit logging",
    "Comprehensive observability with metrics and health endpoints",
    "Modular Rust architecture with clean crate boundaries",
    "High-performance concurrent operations"
  ],
  "publicApiSurface": [
    "Server: serve, check-config, gen-password-hash",
    "DDL: CREATE TABLE, DROP TABLE",
    "DML: INSERT, SELECT, UPDATE, DELETE",
    "Joins: INNER JOIN, LEFT JOIN",
    "Clauses: WHERE, ORDER BY, LIMIT, OFFSET, GROUP BY, HAVING",
    "Aggregations: COUNT, SUM, AVG, MIN, MAX",
    "Transactions: BEGIN, COMMIT, ROLLBACK",
    "Protocol: Simple Query (Q), Extended Query (Parse/Bind/Execute/Sync)",
    "Endpoints: /metrics, /health, /ready",
    "Configuration: server, storage, sharding, cluster, metrics, security"
  ]
